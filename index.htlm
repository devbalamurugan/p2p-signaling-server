<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>P2P Cloud Proxy Share</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; padding: 20px; max-width: 500px; margin: auto; background-color: #f5f5f7; color: #333; }
        .box { border: 1px solid #e5e5ea; padding: 15px; border-radius: 12px; margin-bottom: 15px; background: #ffffff; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        h2, h3 { margin-top: 0; color: #1d1d1f; }
        label { font-weight: 600; font-size: 14px; display: block; margin-top: 10px; margin-bottom: 5px; color: #515154; }
        input, button { width: 100%; padding: 12px; margin: 6px 0; box-sizing: border-box; border-radius: 8px; border: 1px solid #ccc; font-size: 16px; }
        input:focus { outline: none; border-color: #0071e3; }
        button { background-color: #0071e3; color: white; border: none; font-weight: bold; cursor: pointer; transition: background 0.2s; }
        button:hover { background-color: #005bb5; }
        .btn-secondary { background-color: #34c759; }
        .btn-secondary:hover { background-color: #28a745; }
        #chat { height: 250px; border: 1px solid #e5e5ea; overflow-y: auto; padding: 12px; background: #fafafa; border-radius: 8px; display: flex; flex-direction: column; gap: 8px; }
        .msg-line { padding: 8px 12px; border-radius: 8px; max-width: 85%; width: fit-content; word-break: break-all; }
        .msg-me { background: #0071e3; color: white; align-self: flex-end; }
        .msg-them { background: #e5e5ea; color: black; align-self: flex-start; }
        img { max-width: 100%; margin-top: 5px; border-radius: 6px; display: block; }
        .status-badge { font-size: 12px; font-weight: bold; padding: 4px 8px; border-radius: 20px; display: inline-block; margin-bottom: 10px; }
        .status-disconnected { background: #ffebeb; color: #ff3b30; }
        .status-connected { background: #e8f5e9; color: #2e7d32; }
    </style>
</head>
<body>

    <h2>📱 Cloud-Linked P2P Share</h2>
    <div id="statusIndicator" class="status-badge status-disconnected">Disconnected from Local Engine</div>
    
    
    <div class="box">
        <h3>1. Setup Connection</h3>
        <label>Your Cloudflare Tunnel URL:</label>
        <input type="text" id="tunnelUrl" placeholder="paste your ://trycloudflare.com here">
        
        <label>Choose Your Unique Identity ID:</label>
        <input type="text" id="myId" placeholder="e.g., Device_A">
        <button onclick="connectServer()">Connect & Register Identity</button>
    </div>

    <!-- 2. Payload Transmission Pipeline -->
    <div class="box">
        <h3>2. Live Transmission Pipeline</h3>
        <label>Destination Target User ID (To):</label>
        <input type="text" id="targetId" placeholder="e.g., Device_B">
        
        <label>Message Payload:</label>
        <input type="text" id="msgInput" placeholder="Type data structure payload...">
        <button class="btn-secondary" onclick="sendMessage()">Send Secure Text</button>

        <label>Binary Stream Image Payload:</label>
        <input type="file" id="fileInput" accept="image/*" onchange="sendImage()">
    </div>

    <!-- 3. Telemetry Stream Data Logger -->
    <div class="box">
        <h3>3. Active Inbox Telemetry</h3>
        <div id="chat"></div>
    </div>

    <script>
        let ws = null;
        let myId = "";

        function connectServer() {
            let rawUrl = document.getElementById('tunnelUrl').value.trim();
            myId = document.getElementById('myId').value.trim();
            
            if(!rawUrl || !myId) {
                return alert("Fatal: Missing Cloudflare Node URL or personal Identity parameters.");
            }

            // Normalize protocol scheme mappings to eliminate secure contexts mismatches
            let cleanUrl = rawUrl.replace(/^https?:\/\//i, '').replace(/\/$/, '');
            let wssTarget = `wss://${cleanUrl}`;

            const statusIndicator = document.getElementById('statusIndicator');
            statusIndicator.className = "status-badge";
            statusIndicator.innerText = "Attempting Handshake Link...";

            ws = new WebSocket(wssTarget);

            ws.onopen = () => {
                // Initialize identity routing structure packet 
                ws.send(JSON.stringify({ type: 'register', from: myId }));
            };

            ws.onmessage = (event) => {
                const data = JSON.parse(event.data);
                const chat = document.getElementById('chat');

                if (data.type === 'registered') {
                    statusIndicator.className = "status-badge status-connected";
                    statusIndicator.innerText = `Active Session: Registered as [${data.userId}]`;
                    alert(`Handshake complete. Registered securely as: ${data.userId}`);
                } else if (data.type === 'error') {
                    alert(`Signaling Layer Error: ${data.message}`);
                } else if (data.type === 'text') {
                    chat.innerHTML += `<div class="msg-line msg-them"><b>${data.from}:</b><br>${data.data}</div>`;
                    chat.scrollTop = chat.scrollHeight;
                } else if (data.type === 'image') {
                    chat.innerHTML += `<div class="msg-line msg-them"><b>${data.from}:</b><br><img src="${data.data}"></div>`;
                    chat.scrollTop = chat.scrollHeight;
                }
            };

            ws.onclose = () => {
                statusIndicator.className = "status-badge status-disconnected";
                statusIndicator.innerText = "Disconnected from Local Engine";
                alert("Session terminated: WebSocket link broken.");
            };

            ws.onerror = (err) => {
                console.error("Tunnel socket structural failure:", err);
            };
        }

        function sendMessage() {
            const targetId = document.getElementById('targetId').value.trim();
            const msg = document.getElementById('msgInput').value;
            if(!ws || ws.readyState !== WebSocket.OPEN) return alert("Error: Pipeline socket context is down.");
            if(!targetId || !msg) return alert("Validation missing: Destination targeting or packet payload empty.");

            ws.send(JSON.stringify({
                type: 'text',
                from: myId,
                to: targetId,
                data: msg
            }));

            document.getElementById('chat').innerHTML += `<div class="msg-line msg-me"><b>You:</b><br>${msg}</div>`;
            document.getElementById('msgInput').value = '';
            document.getElementById('chat').scrollTop = document.getElementById('chat').scrollHeight;
        }

        function sendImage() {
            const targetId = document.getElementById('targetId').value.trim();
            const fileData = document.getElementById('fileInput').files[0];
            
            if(!ws || ws.readyState !== WebSocket.OPEN) return alert("Error: Pipeline socket context is down.");
            if(!targetId || !fileData) return alert("Validation missing: Destination targeting or image attachment empty.");

            const reader = new FileReader();
            reader.onload = function(e) {
                const base64Image = e.target.result;
                
                ws.send(JSON.stringify({
                    type: 'image',
                    from: myId,
                    to: targetId,
                    data: base64Image
                }));

                document.getElementById('chat').innerHTML += `<div class="msg-line msg-me"><b>You:</b><br><img src="${base64Image}"></div>`;
                document.getElementById('chat').scrollTop = document.getElementById('chat').scrollHeight;
            };
            reader.readAsDataURL(fileData);
        }
    </script>
</body>
</html>
